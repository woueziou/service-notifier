# Notifier Client environment configuration
# Copy this file to .env and adjust values as needed.
#
# VITE_API_URL — Backend API URL
#
# Same-origin (reverse proxy at /api):
#   VITE_API_URL=/api
#
# Cross-origin (separate backend domain):
#   VITE_API_URL=https://api.notifier.example.com

VITE_API_URL=/api
