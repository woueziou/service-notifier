# Notifier production environment configuration
# Copy to .env.prod and fill in your values.

PORT=8080

# --- Client ---
# Host port for the client nginx container.
CLIENT_PORT=80

# API URL for the client.
#   Relative path (/api) — requires a reverse proxy routing /api/* to the backend.
#   Full URL (e.g. https://api.mydomain.com) — sends cross-origin requests directly.
VITE_API_URL=https://api.mydomain.com

# --- PostgreSQL ---
# Connection string for your production Postgres instance.
# sslmode=disable is common for internal databases.
# Use sslmode=require if your Postgres has TLS enabled.
DATABASE_URL=postgres://notifier:PASSWORD@postgres:5432/notifier?sslmode=disable

# --- Redis ---
# Single connection string (overrides REDIS_HOST/PORT/PASSWORD/DB if set)
REDIS_URL=redis://default:change-me@redis:6379/0

# --- SMTP (transactional email provider) ---
# For IP-whitelisted relays, leave SMTP_USER and SMTP_PASSWORD empty.
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com

# --- Admin ---
# First admin email — on first run this email is registered as super_admin.
# Remove after the first admin logs in and creates other users.
ADMIN_SEED_EMAIL=admin@yourdomain.com

# --- Workers ---
WORKER_COUNT=5
MAX_RETRIES=3

# --- CORS ---
# Comma-separated origins allowed to make cross-origin requests to the server.
# Must be the exact client origin(s) — the browser requires an explicit origin,
# not "*", when credentials (cookies) are included.
# Examples:
#   CORS_ORIGIN=https://notifier.mydomain.com
#   CORS_ORIGIN=https://notifier.mydomain.com,https://staging.mydomain.com
CORS_ORIGIN=https://notifier.mydomain.com

# --- HMAC (optional, for consumer request signing) ---
# If empty, a temporary key is generated on each restart (dev mode only).
# HMAC_MASTER_KEY=
